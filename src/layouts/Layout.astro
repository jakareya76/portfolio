---
import "@/styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "JAKAREYA AHMED — Full Stack Developer",
  description = "Portfolio of Jakareya Ahmed — Full Stack Developer. Next.js, Node.js, Cloud.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-void text-paper antialiased">
    <div class="grain min-h-screen">
      <slot />
    </div>
  </body>
</html>
