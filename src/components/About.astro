---
import ExperienceLog from "@/components/ExperienceLog.astro";
import { skills } from "@/data/projects.js";

const quoteText =
  "I specialize in architecting modern web systems that are both beautiful and blazing fast";
const highlightWords = ["architecting", "beautiful", "fast"];

const profileStats = [
  { label: "Experience", value: "2+ yrs" },
  { label: "Projects", value: "15+" },
  { label: "Status", value: "Available" },
];
---

<section id="about" class="py-24 lg:py-40 relative z-10">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="border-t border-ghost pt-4 mb-20">
      <span class="font-[family-name:var(--font-mono)] text-muted text-[11px] uppercase tracking-[0.12em]">
        003 / About
      </span>
    </div>

    <div class="mb-24 md:mb-32">
      <p
        class="font-[family-name:var(--font-display)] font-light text-paper leading-[1.1] max-w-5xl"
        style="font-size: clamp(28px, 5vw, 72px);"
      >
        {
          quoteText.split(" ").map((word) => {
            const isHighlight = highlightWords.includes(
              word.replace(/[^a-zA-Z]/g, "")
            );
            return (
              <span class={`inline-block mr-[0.3em] ${isHighlight ? "text-signal" : ""}`}>
                {word}
              </span>
            );
          })
        }
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-5 mb-24 md:mb-32">
      <div class="md:col-span-7 bg-surface border border-ghost p-8 md:p-10 relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-signal/40 to-transparent"></div>
        <div class="flex items-start justify-between mb-8">
          <span class="font-[family-name:var(--font-mono)] text-signal text-[11px] uppercase tracking-[0.12em]">
            Profile
          </span>
          <span class="font-[family-name:var(--font-mono)] text-ghost text-[11px]">01</span>
        </div>
        <h3
          class="font-[family-name:var(--font-display)] font-bold text-paper mb-3"
          style="font-size: clamp(24px, 3vw, 36px);"
        >
          Jakareya Ahmed
        </h3>
        <p class="text-muted leading-relaxed max-w-lg">
          I specialize in architecting modern web systems using cutting-edge
          tech. With deep expertise in both frontend and backend, I engineer
          seamless digital experiences that are both beautiful and blazing fast.
        </p>
        <div class="flex gap-6 mt-8">
          {
            profileStats.map((item) => (
              <div>
                <p class="font-[family-name:var(--font-display)] font-bold text-paper text-lg">
                  {item.value}
                </p>
                <p class="font-[family-name:var(--font-mono)] text-muted text-[10px] uppercase tracking-[0.1em] mt-0.5">
                  {item.label}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="md:col-span-5 bg-surface border border-ghost p-8 md:p-10 flex flex-col justify-between relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent to-signal/30"></div>
        <div class="flex items-start justify-between mb-8">
          <span class="font-[family-name:var(--font-mono)] text-signal text-[11px] uppercase tracking-[0.12em]">
            Location
          </span>
          <span class="font-[family-name:var(--font-mono)] text-ghost text-[11px]">02</span>
        </div>
        <div>
          <h3
            class="font-[family-name:var(--font-display)] font-bold text-paper"
            style="font-size: clamp(24px, 3vw, 36px);"
          >
            Bangladesh
          </h3>
          <p class="text-muted mt-2">
            Available for remote work worldwide.<br />Open to relocation.
          </p>
        </div>
        <div class="flex items-center gap-3 mt-8">
          <span class="inline-block rounded-full h-2 w-2 bg-signal"></span>
          <span class="font-[family-name:var(--font-mono)] text-signal text-[11px] uppercase tracking-[0.12em]">
            Open to opportunities
          </span>
        </div>
      </div>

      <div class="md:col-span-12">
        <ExperienceLog />
      </div>
    </div>

    <div>
      <div class="flex items-center justify-between mb-8">
        <span class="font-[family-name:var(--font-mono)] text-muted text-[11px] uppercase tracking-[0.12em]">
          Technologies & Tools
        </span>
        <span class="font-[family-name:var(--font-mono)] text-ghost text-[11px]">
          {skills.length} skills
        </span>
      </div>

      <div class="border-t border-ghost pt-6 pb-6">
        <div class="flex flex-wrap gap-x-8 md:gap-x-12 gap-y-3">
          {
            skills.map((skill) => (
              <span class="font-[family-name:var(--font-mono)] text-paper text-sm md:text-base hover:text-signal">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
      <div class="border-t border-ghost"></div>
    </div>
  </div>
</section>
