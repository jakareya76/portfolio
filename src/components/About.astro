---
import { experience, skillGroups } from "@/data/projects.js";
---

<section id="about" class="max-w-3xl mx-auto px-6 py-20 md:py-28 border-t border-line">
  <h2 class="eyebrow mb-12 md:mb-16">About</h2>

  <div class="max-w-xl space-y-5 text-muted text-lg leading-relaxed">
    <p>
      I'm a full-stack developer based in Dhaka, Bangladesh. I work across the
      stack — building React and Next.js frontends, the Node.js services behind
      them, and the databases and cloud infrastructure that keep them running.
    </p>
    <p>
      I care about systems that are fast, reliable, and simple to reason about.
      I started in political science, taught myself to code, and have been
      shipping production software ever since.
    </p>
  </div>

  <div class="mt-16 md:mt-20">
    <h3 class="eyebrow mb-7">Experience</h3>
    <div class="border-t border-line">
      {
        experience.map((role) => (
          <div class="py-5 border-b border-line flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
            <div>
              <p class="text-fg font-medium">{role.title}</p>
              <p class="text-muted text-sm mt-0.5">{role.org}</p>
            </div>
            <span class="text-faint text-sm shrink-0">{role.period}</span>
          </div>
        ))
      }
    </div>
  </div>

  <div class="mt-16 md:mt-20">
    <h3 class="eyebrow mb-7">Skills</h3>
    <dl class="space-y-4">
      {
        skillGroups.map((group) => (
          <div class="flex flex-col sm:flex-row sm:gap-8 gap-1">
            <dt class="text-faint text-sm w-32 shrink-0">{group.label}</dt>
            <dd class="text-muted text-sm">{group.items.join("  ·  ")}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
