---
import { experience } from "@/data/projects.js";

const scopeColor = {
  intrepide: "text-signal",
  softvence: "text-paper",
  naptech: "text-paper",
  career: "text-muted",
};
---

<div class="bg-surface border border-ghost relative overflow-hidden experience-log">
  <div class="flex items-center justify-between border-b border-ghost px-5 md:px-6 py-3">
    <div class="flex items-center gap-3">
      <div class="flex gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-ghost"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-ghost"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-ghost"></span>
      </div>
      <span class="font-[family-name:var(--font-mono)] text-muted text-[10px] uppercase tracking-[0.12em] ml-2 hidden sm:inline">
        ~/jakareya/experience
      </span>
    </div>
    <span class="font-[family-name:var(--font-mono)] text-ghost text-[10px]">04</span>
  </div>

  <div class="px-5 md:px-6 pt-5 pb-3 font-[family-name:var(--font-mono)] text-[12px] md:text-[13px]">
    <span class="text-signal">jakareya@portfolio</span>
    <span class="text-muted"> $ </span>
    <span class="text-paper">git log --oneline --author=jakareya</span>
    <span class="inline-block w-[7px] h-[12px] bg-paper ml-1 align-[-1px]"></span>
  </div>

  <ul class="px-5 md:px-6 pb-6 font-[family-name:var(--font-mono)] text-[12px] md:text-[13px] leading-relaxed">
    {
      experience.map((c, i) => (
        <li class="border-l-2 border-transparent hover:border-signal/40 pl-2 -ml-2">
          <details open={i === 0}>
            <summary class="py-2 flex flex-wrap items-baseline gap-x-2 gap-y-1">
              <span class="text-signal">{c.sha}</span>
              <span class="text-muted">({c.date})</span>
              <span class="text-paper">
                <span class={scopeColor[c.scope] || "text-paper"}>{c.type}</span>
                <span class="text-muted">({c.scope})</span>
                <span class="text-muted">:</span> <span class="text-paper">{c.subject}</span>
              </span>
              <span class="ml-auto text-ghost text-[10px] toggle-label">
                <span class="when-closed">[ +expand ]</span>
                <span class="when-open">[ −collapse ]</span>
              </span>
            </summary>
            <div class="pl-4 md:pl-8 pb-3 pt-1 border-l border-ghost ml-2 md:ml-4">
              {c.body.map((line) => (
                <p class="text-muted text-[12px] md:text-[13px] leading-relaxed">
                  <span class="text-ghost">│ </span>{line}
                </p>
              ))}
            </div>
          </details>
        </li>
      ))
    }

    <li class="pt-2 flex items-center">
      <span class="text-signal">jakareya@portfolio</span>
      <span class="text-muted"> $ </span>
      <span class="inline-block w-[7px] h-[14px] bg-paper ml-1"></span>
    </li>
  </ul>
</div>

<style>
  .experience-log details > summary .when-open { display: none; }
  .experience-log details[open] > summary .when-closed { display: none; }
  .experience-log details[open] > summary .when-open { display: inline; }
  .experience-log details > summary:hover .toggle-label { color: #EDB507; }
</style>
