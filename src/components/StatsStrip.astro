---
import { stats } from "@/data/projects.js";

const GITHUB_USER = "jakareya76";
const { latestCommit, counters } = stats;
---

<section class="bg-signal py-10 md:py-14 relative z-10">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="flex items-center justify-between mb-6 md:mb-8">
      <span class="font-[family-name:var(--font-mono)] text-ink/70 text-[10px] uppercase tracking-[0.12em]">
        // signals
      </span>
      <span class="font-[family-name:var(--font-mono)] text-ink/50 text-[10px] uppercase tracking-[0.12em]">
        live
      </span>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-12 gap-3 md:gap-4">
      <div class="col-span-2 md:col-span-7 border border-ink/15 p-6 md:p-8 flex flex-col justify-between min-h-[150px]">
        <div class="flex items-start justify-between">
          <span class="font-[family-name:var(--font-mono)] text-ink/60 text-[10px] uppercase tracking-[0.12em]">
            Currently
          </span>
          <div class="flex items-center gap-2">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full rounded-full bg-ink opacity-40 live-ping"></span>
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-ink"></span>
            </span>
            <span class="font-[family-name:var(--font-mono)] text-ink/70 text-[10px] uppercase tracking-[0.12em]">
              shipping
            </span>
          </div>
        </div>
        <div>
          <p
            class="font-[family-name:var(--font-display)] font-bold text-ink leading-tight"
            style="font-size: clamp(22px, 2.6vw, 36px);"
          >
            Full Stack Developer<br />
            <span class="text-ink/60">@ Intrepide</span>
          </p>
          <p class="font-[family-name:var(--font-mono)] text-ink/60 text-[11px] mt-3">
            Atlanta, GA — remote from Dhaka
          </p>
        </div>
      </div>

      <div class="col-span-2 md:col-span-5 border border-ink/15 p-6 md:p-8 flex flex-col justify-between min-h-[150px]">
        <span class="font-[family-name:var(--font-mono)] text-ink/60 text-[10px] uppercase tracking-[0.12em]">
          localtime · DAC
        </span>
        <div>
          <p
            class="font-[family-name:var(--font-mono)] font-bold text-ink tabular-nums leading-none"
            style="font-size: clamp(36px, 5vw, 64px);"
          >
            UTC+6
          </p>
          <p class="font-[family-name:var(--font-mono)] text-ink/60 text-[11px] mt-2">
            Dhaka, Bangladesh
          </p>
        </div>
      </div>

      <div class="col-span-2 md:col-span-7 border border-ink/15 p-6 md:p-8 flex flex-col justify-between min-h-[130px]">
        <div class="flex items-center justify-between">
          <span class="font-[family-name:var(--font-mono)] text-ink/60 text-[10px] uppercase tracking-[0.12em]">
            last push
          </span>
          <span class="font-[family-name:var(--font-mono)] text-ink/50 text-[10px]">
            {latestCommit.when}
          </span>
        </div>
        <div>
          <p class="font-[family-name:var(--font-mono)] text-ink text-sm md:text-base leading-snug">
            <span class="text-ink/60">{latestCommit.sha}</span>{" "}
            <span class="break-words">{latestCommit.message}</span>
          </p>
          <p class="font-[family-name:var(--font-mono)] text-ink/60 text-[11px] mt-2">
            {GITHUB_USER}/{latestCommit.repo}
          </p>
        </div>
      </div>

      <div class="col-span-2 md:col-span-5 border border-ink/15 p-6 md:p-8 flex items-center gap-8 md:gap-10 min-h-[130px]">
        {
          counters.map((c) => (
            <div class="flex-1">
              <p
                class="font-[family-name:var(--font-display)] font-bold text-ink leading-none tabular-nums"
                style="font-size: clamp(32px, 4vw, 52px);"
              >
                {c.value}
              </p>
              <p class="font-[family-name:var(--font-mono)] text-ink/60 text-[10px] uppercase tracking-[0.1em] mt-2">
                {c.label}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
