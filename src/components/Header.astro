---
const links = [
  { label: "Work", href: "#work" },
  { label: "About", href: "#about" },
  { label: "Contact", href: "#contact" },
];
---

<header class="fixed inset-x-0 top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-line">
  <nav class="max-w-3xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="#top" class="text-fg text-sm font-medium tracking-tight">
      Jakareya Ahmed
    </a>
    <div class="flex items-center gap-6">
      {
        links.map((link) => (
          <a href={link.href} class="text-faint hover:text-fg text-sm">
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>
