---
import { Image } from "astro:assets";
import { portfolioProjects } from "@/data/projects.js";
---

<section id="projects" class="relative z-10 bg-void py-20 md:py-28">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="flex items-center justify-between gap-6 mb-12 md:mb-16">
      <span class="font-[family-name:var(--font-mono)] text-muted text-[11px] uppercase tracking-[0.12em]">
        002 / Selected Work
      </span>
      <span class="font-[family-name:var(--font-mono)] text-paper text-[11px] tabular-nums tracking-[0.12em]">
        {String(portfolioProjects.length).padStart(2, "0")} projects
      </span>
    </div>

    <div class="flex flex-col gap-10 md:gap-16">
      {
        portfolioProjects.map((project, i) => {
          const hostname = new URL(project.link).hostname.replace(/^www\./, "");
          return (
            <article class="bg-surface relative group border-l-[3px] border-signal">
              <div class="flex flex-col md:flex-row">
                <div class="md:w-[42%] p-8 md:p-12 flex flex-col justify-between min-w-0">
                  <div class="space-y-6">
                    <div class="flex items-center justify-between">
                      <span class="font-[family-name:var(--font-mono)] text-muted text-[11px] uppercase tracking-[0.12em]">
                        PRJ.{String(i + 1).padStart(2, "0")}
                        <span class="text-ghost"> · </span>
                        {project.company}
                        <span class="text-ghost"> · </span>
                        {project.year}
                      </span>
                      <span class="font-[family-name:var(--font-mono)] text-signal text-[10px] uppercase tracking-[0.12em] border border-signal/40 px-2 py-0.5">
                        {project.role}
                      </span>
                    </div>

                    <h3
                      class="font-[family-name:var(--font-display)] font-bold text-paper leading-[1.05]"
                      style="font-size: clamp(26px, 2.7vw, 42px);"
                    >
                      {project.title}
                    </h3>

                    <p class="text-muted text-sm md:text-[15px] leading-relaxed max-w-md">
                      {project.summary}
                    </p>

                    <div class="flex flex-wrap gap-1.5">
                      {project.tech.map((t) => (
                        <span class="font-[family-name:var(--font-mono)] text-paper text-[10px] uppercase tracking-[0.08em] border border-ghost px-2 py-1 hover:border-signal hover:text-signal">
                          {t}
                        </span>
                      ))}
                    </div>

                    <ul class="space-y-2 pt-2">
                      {project.results.map((result) => (
                        <li class="flex items-start gap-3 text-muted text-sm">
                          <span class="text-signal mt-[0.35em] text-[10px]">
                            ▸
                          </span>
                          <span>{result}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="mt-10 flex items-center gap-6">
                    <a
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-paper hover:text-signal font-[family-name:var(--font-display)] text-sm px-4 py-2.5 -mx-4 border border-signal hover:bg-signal/10"
                    >
                      <span class="w-1.5 h-1.5 rounded-full bg-signal" />
                      Live site
                      <span>↗</span>
                    </a>
                    <span class="font-[family-name:var(--font-mono)] text-ghost text-[10px] uppercase tracking-[0.12em]">
                      {hostname}
                    </span>
                  </div>
                </div>

                <div class="md:w-[58%] relative aspect-[4/3] md:aspect-auto overflow-hidden border-l border-ghost/60">
                  <span
                    class="absolute bottom-4 right-4 md:bottom-8 md:right-10 font-[family-name:var(--font-display)] font-bold text-outline pointer-events-none select-none leading-none z-10"
                    style="font-size: clamp(120px, 22vw, 320px); mix-blend-mode: difference;"
                  >
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <div class="absolute inset-0">
                    <Image
                      src={project.image}
                      alt={project.title}
                      class="w-full h-full object-cover object-top"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-void/50 via-void/10 to-void/30" />
                  </div>
                </div>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
