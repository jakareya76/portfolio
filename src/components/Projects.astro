---
import { Image } from "astro:assets";
import { portfolioProjects } from "@/data/projects.js";
---

<section id="work" class="max-w-3xl mx-auto px-6 py-20 md:py-28 border-t border-line">
  <div class="flex items-baseline justify-between mb-12 md:mb-16">
    <h2 class="eyebrow">Selected work</h2>
    <span class="eyebrow">
      {String(portfolioProjects.length).padStart(2, "0")}
    </span>
  </div>

  <div class="space-y-20 md:space-y-28">
    {
      portfolioProjects.map((project, i) => {
        const imageLeft = i % 2 === 0;
        return (
          <article class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
            <div class={imageLeft ? "md:order-2" : ""}>
              <div class="flex items-baseline justify-between gap-4 mb-3">
                <h3
                  class="text-fg text-2xl font-medium"
                  style="letter-spacing: -0.01em;"
                >
                  {project.title}
                </h3>
                <span class="text-faint text-sm shrink-0">{project.year}</span>
              </div>

              <p class="text-muted leading-relaxed">{project.summary}</p>

              <p class="text-faint text-sm mt-4">{project.tech.join("  ·  ")}</p>

              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block mt-5 text-fg text-sm hover:underline underline-offset-4"
              >
                Live site ↗
              </a>
            </div>

            <div class={imageLeft ? "md:order-1" : ""}>
              <div class="border border-line rounded-lg overflow-hidden bg-surface aspect-[16/10]">
                <Image
                  src={project.image}
                  alt={project.title}
                  class="w-full h-full object-cover object-top"
                />
              </div>
            </div>
          </article>
        );
      })
    }
  </div>
</section>
