---
import { email } from "@/data/projects.js";
---

<section id="top" class="max-w-3xl mx-auto px-6 pt-40 pb-24 md:pt-48 md:pb-32">
  <p class="eyebrow mb-6">Full-stack developer · Dhaka, Bangladesh</p>

  <h1
    class="text-fg font-semibold"
    style="font-size: clamp(40px, 8vw, 76px); line-height: 1.05; letter-spacing: -0.03em;"
  >
    Jakareya Ahmed
  </h1>

  <p class="mt-8 max-w-xl text-muted text-lg md:text-xl leading-relaxed">
    I design and build fast, reliable web systems — from frontend interfaces to
    backend services and the cloud infrastructure behind them.
  </p>

  <div class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-3 text-sm">
    <a href="#work" class="text-fg hover:underline underline-offset-4">
      View work →
    </a>
    <a href="/jakareya-cv.pdf" download class="text-muted hover:text-fg">
      Download CV →
    </a>
    <a href={`mailto:${email}`} class="text-muted hover:text-fg">
      Email →
    </a>
  </div>
</section>
