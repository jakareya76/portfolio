---
import { socialLinks } from "@/data/projects.js";

const year = new Date().getFullYear();
---

<section id="contact" class="pt-24 lg:pt-32 pb-32 lg:pb-40 relative z-10">
  <div class="max-w-7xl mx-auto px-6 md:px-10">
    <div class="border-t border-ghost pt-4 mb-20">
      <span class="font-[family-name:var(--font-mono)] text-muted text-[11px] uppercase tracking-[0.12em]">
        004 / Let's Work
      </span>
    </div>

    <div class="grid md:grid-cols-2 gap-16 md:gap-20">
      <div>
        <h2
          class="font-[family-name:var(--font-display)] font-bold text-paper leading-none"
          style="font-size: clamp(44px, 7vw, 100px);"
        >
          Start a<br /><span class="text-signal">project</span>
        </h2>

        <a
          href="mailto:jakareya1306@gmail.com"
          class="inline-block mt-10 px-4 py-3 -mx-4 hover:text-signal"
        >
          <span class="font-[family-name:var(--font-display)] text-paper hover:text-signal text-lg md:text-xl">
            jakareya1306@gmail.com
          </span>
        </a>

        <p class="font-[family-name:var(--font-mono)] text-muted text-xs mt-4">
          Or
          <a
            href="/jakareya-cv.pdf"
            download
            class="text-paper underline underline-offset-4 hover:text-signal"
          >
            download my CV
          </a>
        </p>
      </div>

      <div class="flex flex-col justify-between">
        <div class="space-y-4">
          {
            socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center justify-between py-3 px-4 -mx-4 border-b border-ghost hover:border-signal/40 group"
              >
                <span class="font-[family-name:var(--font-mono)] text-muted group-hover:text-paper text-sm">
                  {social.name}
                </span>
                <span class="text-muted group-hover:text-signal">↗</span>
              </a>
            ))
          }
        </div>

        <div class="mt-12">
          <p class="font-[family-name:var(--font-mono)] text-ghost text-xs">
            Bangladesh — Remote
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-ghost mt-24 pt-6 flex items-center justify-between">
      <span class="font-[family-name:var(--font-mono)] text-ghost text-[10px]">
        &copy; {year} Jakareya Ahmed
      </span>
      <a
        href="#home"
        class="font-[family-name:var(--font-mono)] text-ghost hover:text-signal text-[10px] px-3 py-1.5"
      >
        Back to top ↑
      </a>
    </div>
  </div>
</section>
