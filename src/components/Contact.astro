---
import { socialLinks, email } from "@/data/projects.js";

const year = new Date().getFullYear();
---

<section id="contact" class="max-w-3xl mx-auto px-6 py-20 md:py-28 border-t border-line">
  <h2 class="eyebrow mb-12 md:mb-16">Contact</h2>

  <h3
    class="text-fg font-semibold"
    style="font-size: clamp(30px, 6vw, 52px); line-height: 1.1; letter-spacing: -0.02em;"
  >
    Let's build something.
  </h3>

  <p class="mt-5 max-w-md text-muted leading-relaxed">
    I'm open to new opportunities and collaborations. The fastest way to reach me
    is by email.
  </p>

  <a
    href={`mailto:${email}`}
    class="inline-block mt-8 text-fg text-lg hover:underline underline-offset-4"
  >
    {email}
  </a>

  <div class="mt-12 flex flex-wrap gap-x-8 gap-y-3 text-sm">
    {
      socialLinks.map((social) => (
        <a
          href={social.url}
          target="_blank"
          rel="noopener noreferrer"
          class="text-muted hover:text-fg"
        >
          {social.name} ↗
        </a>
      ))
    }
    <a href="/jakareya-cv.pdf" download class="text-muted hover:text-fg">
      CV ↓
    </a>
  </div>

  <div
    class="mt-20 pt-6 border-t border-line flex items-center justify-between text-faint text-xs"
  >
    <span>© {year} Jakareya Ahmed</span>
    <a href="#top" class="hover:text-fg">Back to top ↑</a>
  </div>
</section>
